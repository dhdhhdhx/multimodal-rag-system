# ============================================================
# Multimodal RAG System - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp deploy/.env.example .env
# ============================================================

# ── MySQL ───────────────────────────────────────────────────
MYSQL_DATABASE=knowledge_management
MYSQL_ROOT_PASSWORD=your-mysql-root-password
MYSQL_PORT=3308

# ── PostgreSQL + PgVector ───────────────────────────────────
PGVECTOR_DB=vector_db
PGVECTOR_USER=user
PGVECTOR_PASSWORD=your-pgvector-password
PGVECTOR_PORT=15432

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT=6379

# ── LLM / AI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
OPENAI_CHAT_MODEL=qwen-plus
OPENAI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
OPENAI_EMBEDDING_MODEL=text-embedding-v3

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret-in-production

# ── Aliyun OSS (optional, for cloud storage) ────────────────
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=

# ── Frontend ───────────────────────────────────────────────
FRONTEND_PORT=80

# ── Alibaba Cloud ACR (for push script) ─────────────────────
ACR_REGISTRY=your-registry.cn-hangzhou.cr.aliyuncs.com
ACR_NAMESPACE=your-namespace
ACR_IMAGE_TAG=latest
